generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CARD
  BANK_TRANSFER
  CASH
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique @db.VarChar(30)
  users User[]

  @@map("roles")
}

model User {
  id                    Int                   @id @default(autoincrement())
  roleId                Int                   @map("role_id")
  firstName             String                @map("first_name") @db.VarChar(50)
  lastName              String                @map("last_name") @db.VarChar(50)
  phone                 String                @db.VarChar(20)
  email                 String                @unique @db.VarChar(100)
  age                   Int?
  passwordHash          String                @map("password_hash") @db.VarChar(255)
  createdAt             DateTime              @default(now()) @map("created_at")
  role                  Role                  @relation(fields: [roleId], references: [id], onDelete: Restrict)
  ownedProperties       Property[]            @relation("PropertyOwner")
  bookings              Booking[]             @relation("BookingRenter")
  reviews               Review[]
  reminders             Reminder[]
  submittedVerifications VerificationRequest[] @relation("VerificationOwner")
  reviewedVerifications VerificationRequest[] @relation("VerificationAdmin")

  @@index([roleId])
  @@map("users")
}

model PropertyType {
  id         Int        @id @default(autoincrement())
  name       String     @unique @db.VarChar(50)
  properties Property[]

  @@map("property_types")
}

model Property {
  id                 Int                   @id @default(autoincrement())
  ownerId            Int                   @map("owner_id")
  propertyTypeId     Int                   @map("property_type_id")
  name               String                @db.VarChar(120)
  address            String                @db.VarChar(255)
  description        String?
  rating             Decimal?              @db.Decimal(3, 2)
  photoUrl           String?               @map("photo_url") @db.VarChar(255)
  verificationStatus VerificationStatus    @default(PENDING) @map("verification_status")
  createdAt          DateTime              @default(now()) @map("created_at")
  owner              User                  @relation("PropertyOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  propertyType       PropertyType          @relation(fields: [propertyTypeId], references: [id], onDelete: Restrict)
  rooms              Room[]
  reviews            Review[]
  verificationRequests VerificationRequest[]

  @@index([ownerId])
  @@index([propertyTypeId])
  @@map("properties")
}

model Room {
  id          Int       @id @default(autoincrement())
  propertyId  Int       @map("property_id")
  name        String    @db.VarChar(100)
  capacity    Int
  pricePerUnit Decimal  @map("price_per_unit") @db.Decimal(10, 2)
  isActive    Boolean   @default(true) @map("is_active")
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  bookings    Booking[]

  @@index([propertyId])
  @@map("rooms")
}

model Booking {
  id            Int           @id @default(autoincrement())
  roomId        Int           @map("room_id")
  renterId      Int           @map("renter_id")
  startDatetime DateTime      @map("start_datetime")
  endDatetime   DateTime      @map("end_datetime")
  totalPrice    Decimal       @map("total_price") @db.Decimal(10, 2)
  serviceFee    Decimal       @map("service_fee") @db.Decimal(10, 2)
  ownerIncome   Decimal       @map("owner_income") @db.Decimal(10, 2)
  bookingStatus BookingStatus @default(PENDING) @map("booking_status")
  paymentStatus PaymentStatus @default(PENDING) @map("payment_status")
  createdAt     DateTime      @default(now()) @map("created_at")
  room          Room          @relation(fields: [roomId], references: [id], onDelete: Restrict)
  renter        User          @relation("BookingRenter", fields: [renterId], references: [id], onDelete: Restrict)
  payments      Payment[]
  reminders     Reminder[]

  @@index([roomId])
  @@index([renterId])
  @@index([startDatetime, endDatetime])
  @@map("bookings")
}

model Payment {
  id            Int           @id @default(autoincrement())
  bookingId     Int           @map("booking_id")
  amount        Decimal       @db.Decimal(10, 2)
  paymentDate   DateTime      @default(now()) @map("payment_date")
  paymentMethod PaymentMethod @map("payment_method")
  paymentStatus PaymentStatus @default(PENDING) @map("payment_status")
  booking       Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("payments")
}

model Review {
  id         Int      @id @default(autoincrement())
  propertyId Int      @map("property_id")
  userId     Int      @map("user_id")
  rating     Int
  comment    String?
  createdAt  DateTime @default(now()) @map("created_at")
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([userId])
  @@map("reviews")
}

model VerificationRequest {
  id          Int                @id @default(autoincrement())
  ownerId     Int                @map("owner_id")
  propertyId  Int                @map("property_id")
  adminId     Int?               @map("admin_id")
  status      VerificationStatus @default(PENDING)
  requestDate DateTime           @default(now()) @map("request_date")
  decisionDate DateTime?         @map("decision_date")
  comment     String?
  owner       User               @relation("VerificationOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  property    Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  admin       User?              @relation("VerificationAdmin", fields: [adminId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([propertyId])
  @@index([adminId])
  @@map("verification_requests")
}

model Reminder {
  id        Int      @id @default(autoincrement())
  bookingId Int      @map("booking_id")
  userId    Int      @map("user_id")
  remindAt  DateTime @map("remind_at")
  isSent    Boolean  @default(false) @map("is_sent")
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([userId])
  @@map("reminders")
}
